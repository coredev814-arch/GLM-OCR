# Server
HOST=0.0.0.0
PORT=8889
LOG_LEVEL=INFO

# Model
MODEL_PATH=zai-org/GLM-OCR
DEVICE_MAP=auto
TORCH_DTYPE=auto           # auto | bfloat16 | float16 | float32
TRUST_REMOTE_CODE=true

# Generation defaults (overridable per request)
MAX_NEW_TOKENS=8192
DO_SAMPLE=false
TEMPERATURE=0.0
TOP_P=1.0
REPETITION_PENALTY=1.05        # >1.0 discourages verbatim n-gram repetition
NO_REPEAT_NGRAM_SIZE=12        # hard-blocks any 12-gram from repeating (0 = off)
SKIP_SPECIAL_TOKENS=false  # GLM-OCR emits layout/structure tokens — keep false

# Concurrency (single GPU → keep at 1; bump if you have multi-GPU or headroom)
MAX_CONCURRENT_INFERENCES=1

# PDF handling
PDF_DPI=200
PDF_MAX_PAGES=32

# Request limits
MAX_UPLOAD_BYTES=52428800
MAX_BATCH_SIZE=16

# HuggingFace cache location (optional)
# HF_HOME=/workspace/.cache/huggingface

# Default OCR prompt when none is supplied
DEFAULT_PROMPT=Text Recognition:
